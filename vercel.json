{
  "rewrites": [
    { "source": "/health", "destination": "https://assistant-pme.onrender.com/health" },
    { "source": "/auth/:path*", "destination": "https://assistant-pme.onrender.com/auth/:path*" },
    { "source": "/chat/:path*", "destination": "https://assistant-pme.onrender.com/chat/:path*" },
    { "source": "/tickets/:path*", "destination": "https://assistant-pme.onrender.com/tickets/:path*" },
    { "source": "/kb/:path*", "destination": "https://assistant-pme.onrender.com/kb/:path*" },
    { "source": "/users/:path*", "destination": "https://assistant-pme.onrender.com/users/:path*" },
    { "source": "/admin/:path*", "destination": "https://assistant-pme.onrender.com/admin/:path*" },
    { "source": "/org/:path*", "destination": "https://assistant-pme.onrender.com/org/:path*" },
    { "source": "/notifications/:path*", "destination": "https://assistant-pme.onrender.com/notifications/:path*" },
    { "source": "/ingest/:path*", "destination": "https://assistant-pme.onrender.com/ingest/:path*" },
    { "source": "/oauth/:path*", "destination": "https://assistant-pme.onrender.com/oauth/:path*" },
    { "source": "/tenants/:path*", "destination": "https://assistant-pme.onrender.com/tenants/:path*" },
    { "source": "/docs/:path*", "destination": "https://assistant-pme.onrender.com/docs/:path*" },
    { "source": "/billing/:path*", "destination": "https://assistant-pme.onrender.com/billing/:path*" },
    { "source": "/leads/:path*", "destination": "https://assistant-pme.onrender.com/leads/:path*" },
    { "source": "/api/:path*", "destination": "https://assistant-pme.onrender.com/api/:path*" },
    { "source": "/", "destination": "https://assistant-pme.onrender.com/app/index.html" },
    { "source": "/app", "destination": "https://assistant-pme.onrender.com/app/index.html" },
    { "source": "/app/", "destination": "https://assistant-pme.onrender.com/app/index.html" },
    { "source": "/app/:path*", "destination": "https://assistant-pme.onrender.com/app/:path*" }
  ],
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
