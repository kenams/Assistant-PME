{
  "rewrites": [
    { "source": "/", "destination": "/app/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/", "destination": "/app/index.html" },
    { "source": "/app/index.html", "destination": "/app/index.html" },
    { "source": "/app/login", "destination": "/app/login.html" },
    { "source": "/app/login/", "destination": "/app/login.html" },
    { "source": "/app/user", "destination": "/app/user.html" },
    { "source": "/app/user/", "destination": "/app/user.html" },
    { "source": "/app/admin", "destination": "/app/admin.html" },
    { "source": "/app/admin/", "destination": "/app/admin.html" }
  ],
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
